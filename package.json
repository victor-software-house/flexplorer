{
	"name": "flexplorer",
	"version": "4.2.0",
	"description": "Obsidian File Explorer Enhancer",
	"author": "kh4f, victor-software-house",
	"license": "MIT",
	"repository": "https://github.com/victor-software-house/flexplorer",
	"bugs": "https://github.com/victor-software-house/flexplorer/issues",
	"homepage": "https://github.com/victor-software-house/flexplorer#readme",
	"keywords": [
		"flexplorer",
		"obsidian-flexplorer",
		"obsidian-plugin",
		"obsidian-file-explorer"
	],
	"trustedDependencies": [
		"obsidian-typings"
	],
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "tsdown",
		"watch": "tsdown -w",
		"prod": "bun -b tsdown -p",
		"build": "bun prod",
		"typecheck": "tsc",
		"lint": "eslint",
		"changeset": "changeset",
		"version": "changeset version && bun scripts/version-bump.ts",
		"release": "bun run build && bun scripts/release.ts"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@eslint-react/eslint-plugin": "^5.8.16",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@tsdown/css": "^0.22.2",
		"@types/bun": "^1.3.14",
		"@types/react-dom": "^19.2.3",
		"@voicss/eslint": "^0.3.0",
		"@voicss/vite": "^0.2.3",
		"eslint": "^10.4.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"jiti": "^2.7.0",
		"obsidian": "^1.13.0",
		"obsidian-typings": "^6.13.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	}
}